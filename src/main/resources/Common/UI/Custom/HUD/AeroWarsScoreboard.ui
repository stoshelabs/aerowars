// Side scoreboard. Uses the SAME container widget/textures as the party modals ($C.@Container from
// AeroWarsUI.ui). The panel lives inside a full-screen transparent root and is pinned to the right
// edge with its vertical axis left unspecified, so it centres vertically the same way the modal
// @Container centres inside @PageOverlay. Element ids stay in sync with ScoreboardHud.java; the
// whole thing is shown/hidden by toggling #AwSbRoot.Visible.
$C = "../AeroWarsUI.ui";

Group #AwSbRoot {
  Anchor: (Left: 0, Right: 0, Top: 0, Bottom: 0);
  Visible: false;

  $C.@Container #AwSbPanel {
    Anchor: (Right: 16, Width: 244, Height: 348);

    #Title {
      $C.@Title #AwSbTitle { @Text = "AEROWARS"; }
    }

    #Content {
      LayoutMode: Top;
      Padding: (Top: 14, Bottom: 14, Left: 16, Right: 16);

      Label #AwSbArena {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #ffffff, HorizontalAlignment: Start);
        Anchor: (Horizontal: 0, Height: 18);
      }
      Label #AwSbMode {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #96a9be, HorizontalAlignment: Start);
        Anchor: (Horizontal: 0, Height: 18, Top: 3);
      }

      Group #AwSbRule1 { Anchor: (Horizontal: 0, Height: 1, Top: 10); Background: (Color: #7a9cc655); }

      Label #AwSbTime {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 26, TextColor: #E8A93B, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Horizontal: 0, Height: 32, Top: 8);
      }
      Label #AwSbTimeLabel {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #878e9c, RenderUppercase: true, HorizontalAlignment: Center);
        Anchor: (Horizontal: 0, Height: 14, Top: 1);
      }

      Group #AwSbEventSection {
        Anchor: (Horizontal: 0, Top: 10, Height: 46);
        Visible: false;
        LayoutMode: Top;

        Group #AwSbEventRule { Anchor: (Horizontal: 0, Height: 1); Background: (Color: #7ae0ff44); }
        Label #AwSbEventName {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #7ac0ff, RenderBold: true, RenderUppercase: true, HorizontalAlignment: Center);
          Anchor: (Horizontal: 0, Height: 16, Top: 6);
        }
        Label #AwSbEventTime {
          Text: "";
          Style: (...$C.@DefaultLabelStyle, FontSize: 19, TextColor: #7ae0ff, RenderBold: true, HorizontalAlignment: Center);
          Anchor: (Horizontal: 0, Height: 22, Top: 1);
        }
      }

      Group #AwSbRule2 { Anchor: (Horizontal: 0, Height: 1, Top: 10); Background: (Color: #ffffff1f); }

      Label #AwSbAlive {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 15, TextColor: #9dffa8, RenderBold: true, HorizontalAlignment: Start);
        Anchor: (Horizontal: 0, Height: 20, Top: 9);
      }
      Label #AwSbKills {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 15, TextColor: #ff9d9d, RenderBold: true, HorizontalAlignment: Start);
        Anchor: (Horizontal: 0, Height: 20, Top: 3);
      }

      Group #AwSbRule3 { Anchor: (Horizontal: 0, Height: 1, Top: 10); Background: (Color: #ffffff1f); }

      Label #AwSbKit {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #96a9be, HorizontalAlignment: Start);
        Anchor: (Horizontal: 0, Height: 18, Top: 9);
      }

      // Flexible spacer pushes the footer to the bottom of the panel.
      Group { Anchor: (Horizontal: 0); FlexWeight: 1; }

      Group #AwSbFooterRule { Anchor: (Horizontal: 0, Height: 1, Bottom: 6); Background: (Color: #ffffff14); }
      Label #AwSbFooter {
        Text: "";
        Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #7ac0ff, RenderBold: true, HorizontalAlignment: Center);
        Anchor: (Horizontal: 0, Height: 16);
      }
    }
  }
}
