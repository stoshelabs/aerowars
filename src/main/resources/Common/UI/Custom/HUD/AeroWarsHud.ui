Group #AeroWarsRoot {
  Anchor: (Right: 16, Top: 80, Width: 224, Height: 148);
  Background: (Color: #14162ad8);
  Visible: false;
  LayoutMode: Top;
  Padding: (Left: 14, Right: 14, Top: 10, Bottom: 10);

  Label #AwTitle {
    Text: "AEROWARS";
    Style: (FontSize: 18, TextColor: #55ccff, RenderBold: true, HorizontalAlignment: Center);
    Anchor: (Horizontal: 0, Height: 24);
  }

  Label #AwPhase {
    Text: "";
    Style: (FontSize: 13, TextColor: #ffffff, RenderBold: false, HorizontalAlignment: Center);
    Anchor: (Horizontal: 0, Height: 18, Top: 4);
  }

  Label #AwTimer {
    Text: "";
    Style: (FontSize: 24, TextColor: #ffdd55, RenderBold: true, HorizontalAlignment: Center);
    Anchor: (Horizontal: 0, Height: 30, Top: 4);
  }

  Label #AwAlive {
    Text: "";
    Style: (FontSize: 14, TextColor: #9dffa8, RenderBold: true, HorizontalAlignment: Center);
    Anchor: (Horizontal: 0, Height: 18, Top: 6);
  }

  Label #AwKit {
    Text: "";
    Style: (FontSize: 12, TextColor: #c9c9d6, RenderBold: false, HorizontalAlignment: Center);
    Anchor: (Horizontal: 0, Height: 16, Top: 4);
  }
}
