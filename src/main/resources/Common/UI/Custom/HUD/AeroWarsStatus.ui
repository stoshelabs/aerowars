Group #AwStatusRoot {
  Anchor: (Horizontal: 0, Top: 96, Width: 400, Height: 74);
  Visible: false;
  LayoutMode: Top;

  // Top accent (two bars = faux gradient edge).
  Group #AwStatusAccentA {
    Anchor: (Horizontal: 0, Height: 2);
    Background: (Color: #7ae0ffff);
  }
  Group #AwStatusAccentB {
    Anchor: (Horizontal: 0, Height: 2);
    Background: (Color: #3aa0ffcc);
  }

  Group #AwStatusPanel {
    Anchor: (Horizontal: 0, Top: 0, Bottom: 0);
    Background: (Color: #0b1020ee);
    LayoutMode: Top;
    Padding: (Left: 20, Right: 20, Top: 9, Bottom: 9);

    Label #AwStatusMain {
      Text: "";
      Style: (FontSize: 26, TextColor: #ffffff, RenderBold: true, HorizontalAlignment: Center, ShrinkTextToFit: true, MinShrinkTextToFitFontSize: 16);
      Anchor: (Horizontal: 0, Height: 32);
    }

    Label #AwStatusSub {
      Text: "";
      Style: (FontSize: 13, TextColor: #9fb0c8, RenderBold: false, HorizontalAlignment: Center);
      Anchor: (Horizontal: 0, Height: 18, Top: 3);
    }
  }

  // Bottom accent.
  Group #AwStatusAccentC {
    Anchor: (Horizontal: 0, Bottom: 0, Height: 2);
    Background: (Color: #3aa0ffcc);
  }
}
