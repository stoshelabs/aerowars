$C = "../AeroWarsUI.ui";
$Sounds = "../AeroWarsSounds.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 580, Height: 600);

  #Title { $C.@Title #KitTitle { @Text = "SELECT KIT"; } }

  #Content {
    LayoutMode: Top;
    Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

    // ---- list view ----
    Group #KitListView {
      FlexWeight: 1; LayoutMode: Top; Visible: false;
      Label #KitSubtitle { Anchor: (Horizontal: 0, Height: 18, Bottom: 10); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #b2c1d0); Text: ""; }
      Label #KitEmpty { Anchor: (Horizontal: 0, Height: 18, Bottom: 6); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6a6a6); Text: ""; Visible: false; }
      Group { Anchor: (Horizontal: 0, Bottom: 0); FlexWeight: 1; LayoutMode: TopScrolling; ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Group #KitRow0 { Anchor: (Height: 40, Horizontal: 0, Bottom: 5); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; Group { FlexWeight: 1; Anchor: (Vertical: 0, Height: 34); LayoutMode: Top; Label #KitName0 { Anchor: (Horizontal: 0, Height: 18); Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); Text: ""; } Label #KitInfo0 { Anchor: (Horizontal: 0, Height: 14, Top: 1); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc); Text: ""; } } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #BtnKitView0 { @Anchor = (Width: 90, Height: 30); Text: "View"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnKitSelect0 { @Anchor = (Width: 100, Height: 30); Text: "Select"; } }
        Group #KitRow1 { Anchor: (Height: 40, Horizontal: 0, Bottom: 5); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; Group { FlexWeight: 1; Anchor: (Vertical: 0, Height: 34); LayoutMode: Top; Label #KitName1 { Anchor: (Horizontal: 0, Height: 18); Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); Text: ""; } Label #KitInfo1 { Anchor: (Horizontal: 0, Height: 14, Top: 1); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc); Text: ""; } } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #BtnKitView1 { @Anchor = (Width: 90, Height: 30); Text: "View"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnKitSelect1 { @Anchor = (Width: 100, Height: 30); Text: "Select"; } }
        Group #KitRow2 { Anchor: (Height: 40, Horizontal: 0, Bottom: 5); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; Group { FlexWeight: 1; Anchor: (Vertical: 0, Height: 34); LayoutMode: Top; Label #KitName2 { Anchor: (Horizontal: 0, Height: 18); Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); Text: ""; } Label #KitInfo2 { Anchor: (Horizontal: 0, Height: 14, Top: 1); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc); Text: ""; } } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #BtnKitView2 { @Anchor = (Width: 90, Height: 30); Text: "View"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnKitSelect2 { @Anchor = (Width: 100, Height: 30); Text: "Select"; } }
        Group #KitRow3 { Anchor: (Height: 40, Horizontal: 0, Bottom: 5); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; Group { FlexWeight: 1; Anchor: (Vertical: 0, Height: 34); LayoutMode: Top; Label #KitName3 { Anchor: (Horizontal: 0, Height: 18); Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); Text: ""; } Label #KitInfo3 { Anchor: (Horizontal: 0, Height: 14, Top: 1); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc); Text: ""; } } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #BtnKitView3 { @Anchor = (Width: 90, Height: 30); Text: "View"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnKitSelect3 { @Anchor = (Width: 100, Height: 30); Text: "Select"; } }
        Group #KitRow4 { Anchor: (Height: 40, Horizontal: 0, Bottom: 5); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; Group { FlexWeight: 1; Anchor: (Vertical: 0, Height: 34); LayoutMode: Top; Label #KitName4 { Anchor: (Horizontal: 0, Height: 18); Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); Text: ""; } Label #KitInfo4 { Anchor: (Horizontal: 0, Height: 14, Top: 1); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc); Text: ""; } } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #BtnKitView4 { @Anchor = (Width: 90, Height: 30); Text: "View"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnKitSelect4 { @Anchor = (Width: 100, Height: 30); Text: "Select"; } }
