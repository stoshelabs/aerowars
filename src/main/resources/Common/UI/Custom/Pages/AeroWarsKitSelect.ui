      }
    }

    // ---- detail view (kit contents) ----
    Group #KitDetailView {
      FlexWeight: 1; LayoutMode: Top; Visible: false;
      Group { Anchor: (Horizontal: 0, Height: 30, Bottom: 8); LayoutMode: Left;
        $C.@SmallSecondaryTextButton #BtnKitBack { @Anchor = (Width: 100, Vertical: 0); Text: "Back"; }
        Group { Anchor: (Width: 12); }
        Label #KitDetailTitle { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #7ac0ff, RenderBold: true, VerticalAlignment: Center); Text: ""; }
      }
      Label #KitItemEmpty { Anchor: (Horizontal: 0, Height: 18, Bottom: 4); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6a6a6); Text: ""; Visible: false; }
      Group { Anchor: (Horizontal: 0, Bottom: 8); FlexWeight: 1; LayoutMode: TopScrolling; ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Group #KitItemRow0 { Anchor: (Height: 28, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; ItemSlot #KitItemIcon0 { Anchor: (Width: 22, Height: 22, Vertical: 0); } Group { Anchor: (Width: 8); } Label #KitItemName0 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Label #KitItemQty0 { Anchor: (Height: 18, Vertical: 0, Width: 60); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9dc8ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; } Label #KitItemSlot0 { Anchor: (Height: 18, Vertical: 0, Width: 90); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc, HorizontalAlignment: End, VerticalAlignment: Center); Text: ""; } }
        Group #KitItemRow1 { Anchor: (Height: 28, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; ItemSlot #KitItemIcon1 { Anchor: (Width: 22, Height: 22, Vertical: 0); } Group { Anchor: (Width: 8); } Label #KitItemName1 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Label #KitItemQty1 { Anchor: (Height: 18, Vertical: 0, Width: 60); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #9dc8ff, RenderBold: true, HorizontalAlignment: Center, VerticalAlignment: Center); Text: ""; } Label #KitItemSlot1 { Anchor: (Height: 18, Vertical: 0, Width: 90); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc, HorizontalAlignment: End, VerticalAlignment: Center); Text: ""; } }
