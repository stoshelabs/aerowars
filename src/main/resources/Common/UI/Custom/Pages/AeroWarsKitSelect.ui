        Group #KitRow6 { Anchor: (Height: 40, Horizontal: 0, Bottom: 5); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 14, Right: 12); Visible: false; Group { FlexWeight: 1; Anchor: (Vertical: 0, Height: 34); LayoutMode: Top; Label #KitName6 { Anchor: (Horizontal: 0, Height: 18); Style: (...$C.@DefaultLabelStyle, FontSize: 14, TextColor: #ffffff, RenderBold: true, VerticalAlignment: Center); Text: ""; } Label #KitInfo6 { Anchor: (Horizontal: 0, Height: 14, Top: 1); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8fa4bc); Text: ""; } } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #BtnKitView6 { @Anchor = (Width: 90, Height: 30); Text: "View"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnKitSelect6 { @Anchor = (Width: 100, Height: 30); Text: "Select"; } }
