$C = "../AeroWarsUI.ui";
$Sounds = "../AeroWarsSounds.ui";

$C.@PageOverlay {}

$C.@Container #AdminRoot {
  Anchor: (Width: 980, Height: 600);

  #Title {
    $C.@Title #AdminTitle { @Text = "AEROWARS ADMIN"; }
  }

  #Content {
    LayoutMode: Left;
    Padding: (Top: 16, Bottom: 16, Left: 16, Right: 16);

    Group #AdminNav {
      Anchor: (Width: 196, Top: 0, Bottom: 0);
      LayoutMode: Top;
      $C.@AeroNavButton #NavArenas { @Text = "Arenas"; }
      $C.@AeroNavButtonActive #NavArenasActive { @Text = "Arenas"; Visible: false; }
      $C.@AeroNavButton #NavLoot { @Text = "Loot"; }
      $C.@AeroNavButtonActive #NavLootActive { @Text = "Loot"; Visible: false; }
      $C.@AeroNavButton #NavMatches { @Text = "Matches"; }
      $C.@AeroNavButtonActive #NavMatchesActive { @Text = "Matches"; Visible: false; }
      $C.@AeroNavButton #NavKits { @Text = "Kits"; }
      $C.@AeroNavButtonActive #NavKitsActive { @Text = "Kits"; Visible: false; }
      $C.@AeroNavButton #NavSettings { @Text = "Settings"; }
      $C.@AeroNavButtonActive #NavSettingsActive { @Text = "Settings"; Visible: false; }
      Group { FlexWeight: 1; }
      $C.@SecondaryTextButton #BtnAdminClose { @Sounds = $Sounds.@ButtonsLight; @Anchor = (Horizontal: 0, Height: 36); Text: "Close"; }
    }

    Group { Anchor: (Width: 14); }

    Group #AdminBody {
      FlexWeight: 1;
      Anchor: (Top: 0, Bottom: 0);
      LayoutMode: Top;

      Label #AdminPanelTitle {
        Anchor: (Horizontal: 0, Height: 24);
        Style: (...$C.@DefaultLabelStyle, FontSize: 16, TextColor: #ffffff, RenderBold: true, RenderUppercase: true, LetterSpacing: 1, HorizontalAlignment: Start);
        Text: "";
      }
      Group #AdminTitleRule { Anchor: (Horizontal: 0, Height: 1, Top: 8, Bottom: 10); Background: (Color: #7a9cc655); }

      // ============ ARENAS ============
      Group #PanelArenas {
        FlexWeight: 1; LayoutMode: Top; Visible: false;
        Label #ArenaCount { Anchor: (Horizontal: 0, Height: 18, Bottom: 6); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cbd9e8); Text: ""; }
        Label #ArenaEmpty { Anchor: (Horizontal: 0, Height: 18, Bottom: 6); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6a6a6); Text: ""; Visible: false; }
        Group { Anchor: (Horizontal: 0, Bottom: 0); FlexWeight: 1; LayoutMode: TopScrolling; ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Group #ArenaRow0 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName0 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit0 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests0 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete0 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        Group #ArenaRow1 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName1 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit1 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests1 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete1 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        Group #ArenaRow2 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName2 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit2 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests2 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete2 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        Group #ArenaRow3 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName3 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit3 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests3 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete3 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        Group #ArenaRow4 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName4 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit4 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests4 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete4 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        Group #ArenaRow5 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName5 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit5 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests5 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete5 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        Group #ArenaRow6 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName6 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit6 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests6 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete6 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        Group #ArenaRow7 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #ArenaName7 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaEdit7 { @Anchor = (Width: 80, Height: 28); Text: "Edit"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnArenaChests7 { @Anchor = (Width: 130, Height: 28); Text: "Clear chests"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnArenaDelete7 { @Anchor = (Width: 90, Height: 28); Text: "Delete"; } }
        }
      }

      // ============ LOOT ============
      Group #PanelLoot {
        FlexWeight: 1; LayoutMode: Top; Visible: false;
        Group { Anchor: (Horizontal: 0, Height: 32, Bottom: 8); LayoutMode: Left;
          $C.@SmallSecondaryTextButton #BtnLootNormal { @Anchor = (Width: 110, Vertical: 0); Text: "normal"; }
          Group { Anchor: (Width: 6); }
          $C.@SmallSecondaryTextButton #BtnLootMiddle { @Anchor = (Width: 110, Vertical: 0); Text: "middle"; }
          Group { Anchor: (Width: 12); }
          Label #LootTableLabel { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #7ac0ff, RenderBold: true, VerticalAlignment: Center); Text: ""; }
        }
        Label #LootCount { Anchor: (Horizontal: 0, Height: 18, Bottom: 4); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cbd9e8); Text: ""; }
        Label #LootEmpty { Anchor: (Horizontal: 0, Height: 18, Bottom: 4); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6a6a6); Text: ""; Visible: false; }
        Group { Anchor: (Horizontal: 0, Bottom: 8); FlexWeight: 1; LayoutMode: TopScrolling; ScrollbarStyle: $C.@DefaultScrollbarStyle;
        Group #LootRow0 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName0 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove0 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow1 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName1 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove1 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow2 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName2 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove2 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow3 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName3 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove3 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow4 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName4 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove4 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow5 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName5 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove5 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow6 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName6 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove6 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow7 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName7 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove7 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow8 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName8 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove8 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        Group #LootRow9 { Anchor: (Height: 32, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #LootName9 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnLootRemove9 { @Anchor = (Width: 100, Height: 26); Text: "Remove"; } }
        }
        Label #LootAddHint { Anchor: (Horizontal: 0, Height: 16, Bottom: 4); Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #8b93a7); Text: ""; }
        Group { Anchor: (Horizontal: 0, Height: 34); LayoutMode: Left;
          $C.@TextField #LootAddField { @Anchor = (Vertical: 0); FlexWeight: 1; }
          Group { Anchor: (Width: 8); }
          $C.@SmallSecondaryTextButton #BtnLootAdd { @Anchor = (Width: 120, Vertical: 0); Text: "Add"; }
        }
      }

      // ============ MATCHES ============
      Group #PanelMatches {
        FlexWeight: 1; LayoutMode: Top; Visible: false;

        // ---- list view ----
        Group #MatchListView {
          FlexWeight: 1; LayoutMode: Top; Visible: false;
          Label #MatchCount { Anchor: (Horizontal: 0, Height: 18, Bottom: 6); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cbd9e8); Text: ""; }
          Label #MatchEmpty { Anchor: (Horizontal: 0, Height: 18, Bottom: 6); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6a6a6); Text: ""; Visible: false; }
          Group { Anchor: (Horizontal: 0, Bottom: 0); FlexWeight: 1; LayoutMode: TopScrolling; ScrollbarStyle: $C.@DefaultScrollbarStyle;
          Group #MatchRow0 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #MatchName0 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchView0 { @Anchor = (Width: 96, Height: 28); Text: "Players"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchSpectate0 { @Anchor = (Width: 96, Height: 28); Text: "Spectate"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnMatchEnd0 { @Anchor = (Width: 80, Height: 28); Text: "End"; } }
