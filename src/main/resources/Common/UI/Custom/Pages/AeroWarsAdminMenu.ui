          Group #MatchRow2 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #MatchName2 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchView2 { @Anchor = (Width: 96, Height: 28); Text: "Players"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchSpectate2 { @Anchor = (Width: 96, Height: 28); Text: "Spectate"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnMatchEnd2 { @Anchor = (Width: 80, Height: 28); Text: "End"; } }
          Group #MatchRow3 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #MatchName3 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchView3 { @Anchor = (Width: 96, Height: 28); Text: "Players"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchSpectate3 { @Anchor = (Width: 96, Height: 28); Text: "Spectate"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnMatchEnd3 { @Anchor = (Width: 80, Height: 28); Text: "End"; } }
          Group #MatchRow4 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #MatchName4 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchView4 { @Anchor = (Width: 96, Height: 28); Text: "Players"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchSpectate4 { @Anchor = (Width: 96, Height: 28); Text: "Spectate"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnMatchEnd4 { @Anchor = (Width: 80, Height: 28); Text: "End"; } }
          Group #MatchRow5 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #MatchName5 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchView5 { @Anchor = (Width: 96, Height: 28); Text: "Players"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchSpectate5 { @Anchor = (Width: 96, Height: 28); Text: "Spectate"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnMatchEnd5 { @Anchor = (Width: 80, Height: 28); Text: "End"; } }
          Group #MatchRow6 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #MatchName6 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchView6 { @Anchor = (Width: 96, Height: 28); Text: "Players"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchSpectate6 { @Anchor = (Width: 96, Height: 28); Text: "Spectate"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnMatchEnd6 { @Anchor = (Width: 80, Height: 28); Text: "End"; } }
          Group #MatchRow7 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #1b2740); Padding: (Left: 12, Right: 10); Visible: false; Label #MatchName7 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchView7 { @Anchor = (Width: 96, Height: 28); Text: "Players"; } Group { Anchor: (Width: 6); } $C.@SmallSecondaryTextButton #BtnMatchSpectate7 { @Anchor = (Width: 96, Height: 28); Text: "Spectate"; } Group { Anchor: (Width: 6); } $C.@SmallTertiaryTextButton #BtnMatchEnd7 { @Anchor = (Width: 80, Height: 28); Text: "End"; } }
          }
        }

        // ---- detail view (players of one match) ----
        Group #MatchDetailView {
          FlexWeight: 1; LayoutMode: Top; Visible: false;
          Group { Anchor: (Horizontal: 0, Height: 30, Bottom: 8); LayoutMode: Left;
            $C.@SmallSecondaryTextButton #BtnMatchBack { @Anchor = (Width: 100, Vertical: 0); Text: "Back"; }
            Group { Anchor: (Width: 12); }
            Label #MatchDetailTitle { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #7ac0ff, RenderBold: true, VerticalAlignment: Center); Text: ""; }
          }
          Label #MatchDetailEmpty { Anchor: (Horizontal: 0, Height: 18, Bottom: 4); Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6a6a6); Text: ""; Visible: false; }
          Group { Anchor: (Horizontal: 0, Bottom: 0); FlexWeight: 1; LayoutMode: TopScrolling; ScrollbarStyle: $C.@DefaultScrollbarStyle;
