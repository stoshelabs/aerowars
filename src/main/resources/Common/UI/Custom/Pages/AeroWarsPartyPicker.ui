$C = "../AeroWarsUI.ui";
$Sounds = "../AeroWarsSounds.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 640, Height: 560);

  #Title {
    $C.@Title #PickerTitle { @Text = "INVITE PLAYER"; }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Top: 16, Bottom: 16, Left: 18, Right: 18);

    Label #PickerSubtitle {
      Anchor: (Horizontal: 0, Height: 18, Bottom: 8);
      Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #b2c1d0);
      Text: "";
    }

    Group {
      Anchor: (Horizontal: 0, Height: 34, Bottom: 8);
      LayoutMode: Left;

      $C.@TextField #PickerSearchField { @Anchor = (Vertical: 0); FlexWeight: 1; }
      Group { Anchor: (Width: 8); }
      $C.@SmallSecondaryTextButton #PickerSubmitButton { @Anchor = (Width: 130, Vertical: 0); Text: "Search"; }
    }

    Label #PickerError {
      Anchor: (Horizontal: 0, Height: 18, Bottom: 6);
      Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ff7a7a);
      Text: "";
      Visible: false;
    }

    Label #PickerCountLabel {
      Anchor: (Horizontal: 0, Height: 18, Bottom: 6);
      Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #cbd9e8);
      Text: "Online players: 0";
    }

    Label #PickerEmptyLabel {
      Anchor: (Horizontal: 0, Height: 18, Bottom: 8);
      Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #d6a6a6);
      Text: "No players found.";
      Visible: false;
    }

    Group {
      Anchor: (Horizontal: 0, Bottom: 10);
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;

      Group #PickerRow0 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName0 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction0 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow1 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName1 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction1 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow2 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName2 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction2 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow3 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName3 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction3 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow4 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName4 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction4 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow5 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName5 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction5 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow6 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName6 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction6 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow7 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName7 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction7 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow8 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName8 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction8 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
      Group #PickerRow9 { Anchor: (Height: 34, Horizontal: 0, Bottom: 4); LayoutMode: Left; Background: (Color: #223149); Padding: (Left: 10, Right: 10); Visible: false; Label #PickerName9 { Anchor: (Height: 18, Vertical: 0); FlexWeight: 1; Style: (...$C.@DefaultLabelStyle, FontSize: 12, TextColor: #ffffff, VerticalAlignment: Center); Text: ""; } Group { Anchor: (Width: 8); } $C.@SmallSecondaryTextButton #PickerAction9 { @Anchor = (Width: 110, Height: 28); Text: "Invite"; } }
    }

    $C.@SecondaryTextButton #PickerBackButton {
      @Sounds = $Sounds.@ButtonsCancel;
      @Anchor = (Height: 36, Bottom: 4);
      Text: "Back";
    }
  }
}
