$C = "../AeroWarsUI.ui";
$Sounds = "../AeroWarsSounds.ui";

$C.@PageOverlay {}

$C.@Container {
  Anchor: (Width: 560, Height: 470);

  #Title {
    $C.@Title #ChangelogTitle { @Text = "WHAT'S NEW"; }
  }

  #Content {
    LayoutMode: Top;
    Padding: (Top: 16, Bottom: 20, Left: 24, Right: 24);

    Label #ChangelogSubtitle {
      Anchor: (Horizontal: 0, Height: 20, Bottom: 8);
      Style: (...$C.@DefaultLabelStyle, FontSize: 13, TextColor: #7ae0ff, HorizontalAlignment: Center, VerticalAlignment: Center);
      Text: "";
    }

    Group #ChangelogScroll {
      Anchor: (Horizontal: 0, Bottom: 14);
      FlexWeight: 1;
      LayoutMode: TopScrolling;
      ScrollbarStyle: $C.@DefaultScrollbarStyle;

      Label #ChangelogBody {
        Anchor: (Horizontal: 0, Top: 0);
        Style: (...$C.@DefaultLabelStyle, FontSize: 11, TextColor: #d0dce6, HorizontalAlignment: Start, VerticalAlignment: Start, Wrap: true);
        Text: "";
      }
    }

    Group {
      Anchor: (Horizontal: 0, Height: 40);
      LayoutMode: Left;

      $C.@SecondaryTextButton #BtnChangelogDismiss {
        @Sounds = $Sounds.@ButtonsLight;
        @Anchor = (Height: 36);
        FlexWeight: 1;
        Text: "Don't show until next version";
      }

      Group { Anchor: (Width: 8); }

      $C.@SecondaryTextButton #BtnChangelogClose {
        @Sounds = $Sounds.@ButtonsLight;
        @Anchor = (Height: 36);
        FlexWeight: 1;
        Text: "Close";
      }
    }
  }
}
